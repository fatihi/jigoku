{
    "name": "jigoku",
    "version": "2.0.0",
    "description": "The server code for Jigoku, a browser based implementation of the Legend of the Five Rings LCG",
    "main": "index.js",
    "scripts": {
        "test": "npm run jasmine",
        "jasmine": "tsc && cross-env JASMINE_CONFIG_PATH=./jasmine.json DB_PATH=mongodb://localhost:27017/test DOMAIN=localhost ENVIRONMENT=test GAME_NODE_NAME=test GAME_NODE_SOCKET_IO_PORT=9500 HTTPS=false LOBBY_PORT=4000 LOBBY_WS_URL=ws://localhost:6000 SECRET=testsecret jasmine",
        "lint": "eslint server/ test/server/",
        "typecheck": "tsc --noEmit",
        "typecheck:strict": "tsc --noEmit -p tsconfig.strict.json"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/jigoku/jigoku.git"
    },
    "keywords": [
        "l5r",
        "legend",
        "of",
        "the",
        "five",
        "rings",
        "cardgame"
    ],
    "author": "Ryan Karetas <ryan@karetas.com>",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/jigoku/jigoku/issues"
    },
    "homepage": "https://github.com/jigoku/jigoku#readme",
    "engines": {
        "node": ">=22.0.0"
    },
    "dependencies": {
        "axios": "1.15.0",
        "bcrypt": "6.0.0",
        "connect-mongo": "6.0.0",
        "cookie-parser": "1.4.7",
        "cors": "2.8.6",
        "cross-env": "10.1.0",
        "date-fns": "4.1.0",
        "express": "5.2.1",
        "express-rate-limit": "8.3.0",
        "express-session": "1.19.0",
        "helmet": "8.1.0",
        "jsonwebtoken": "9.0.3",
        "mkdirp": "3.0.1",
        "mongodb": "7.1.0",
        "nodemailer": "8.0.4",
        "passport": "0.7.0",
        "passport-local": "1.0.0",
        "socket.io": "4.8.3",
        "underscore": "1.13.8",
        "uuid": "13.0.0",
        "winston": "3.19.0",
        "winston-daily-rotate-file": "5.0.0",
        "ws": "8.18.0",
        "zod": "4.3.6"
    },
    "devDependencies": {
        "@eslint/js": "10.0.1",
        "@types/bcrypt": "6.0.0",
        "@types/jsonwebtoken": "9.0.10",
        "@types/node": "25.3.5",
        "@typescript-eslint/eslint-plugin": "8.56.1",
        "@typescript-eslint/parser": "8.56.1",
        "eslint": "10.0.3",
        "eslint-plugin-jasmine": "4.2.2",
        "globals": "17.4.0",
        "jasmine": "6.1.0",
        "@types/ws": "8.5.13",
        "prettier": "3.8.1",
        "typescript": "5.9.3"
    },
    "volta": {
        "node": "22.13.0"
    }
}
